FROM debian:bookworm-slim

ARG NODE_VERSION=20
ARG TERRAFORM_VERSION=1.6.6

ENV DEBIAN_FRONTEND=noninteractive
ENV USER=dev
ENV HOME=/home/${USER}

# Install system dependencies
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        unzip \
        git \
        python3 \
        python3-pip \
        python3-venv \
    ; \
    rm -rf /var/lib/apt/lists/*

# Install Node.js (via NodeSource repo for stable official builds)
RUN set -eux; \
    curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash -; \
    apt-get install -y nodejs; \
    rm -rf /var/lib/apt/lists/*

# Install Terraform
RUN set -eux; \
    tmpdir="$(mktemp -d)"; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) tf_arch=linux_amd64 ;; \
      arm64) tf_arch=linux_arm64 ;; \
      *) echo "Unsupported arch: $arch"; exit 1 ;; \
    esac; \
    curl -fsSL \
      "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_${tf_arch}.zip" \
      -o "$tmpdir/terraform.zip"; \
    unzip "$tmpdir/terraform.zip" -d /usr/local/bin; \
    chmod +x /usr/local/bin/terraform; \
    rm -rf "$tmpdir"

# Make python + pip available as generic commands
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3 1 || true && \
    update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1 || true

# Create non-root user
RUN useradd -m -s /bin/bash ${USER}

WORKDIR /workspace
USER ${USER}

ENTRYPOINT ["/bin/bash"]